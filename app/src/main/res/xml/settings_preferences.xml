<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory android:title="@string/appearance">
        <ListPreference
            android:key="themeMode"
            android:title="@string/theme_mode"
            android:entries="@array/theme_entries"
            android:entryValues="@array/theme_values"
            android:defaultValue="system"/>
        <Preference
            android:title="@string/accent_color"
            android:summary="@string/aqua_brand_color"/>
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/notifications">
        <SwitchPreferenceCompat
            android:key="hydrationRemindersEnabled"
            android:title="@string/hydration_reminders"/>
        <Preference
            android:key="notificationTimes"
            android:title="@string/default_times"
            android:summary="@string/default_times_summary"/>
        <SwitchPreferenceCompat
            android:key="notificationSound"
            android:title="@string/sound_vibration"/>
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/data_privacy">
        <Preference
            android:key="clearData"
            android:title="@string/clear_all_data"
            android:summary="@string/clear_all_data_summary"/>
        <Preference
            android:key="privacyPolicy"
            android:title="@string/privacy_policy"/>
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/language">
        <ListPreference
            android:key="language"
            android:title="@string/app_language"
            android:entries="@array/language_entries"
            android:entryValues="@array/language_values"
            android:defaultValue="system"/>
    </PreferenceCategory>

    <Preference
        android:title="@string/app_version"
        android:summary="AquaGlow v1.0"/>

</PreferenceScreen>


